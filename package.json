{
  "name": "flitty",
  "version": "0.1.0",
  "description": "Local screen sharing over WebRTC with a Bun CLI.",
  "type": "module",
  "bin": {
    "flitty": "src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "check:publish": "npm pack --dry-run",
    "build:local": "bun build --compile --minify --outfile dist/flitty ./src/index.ts",
    "build:mac": "bun build --compile --minify --target=bun-darwin-arm64 --outfile dist/flitty-macos ./src/index.ts",
    "build:win": "bun build --compile --minify --target=bun-windows-x64 --outfile dist/flitty-windows.exe ./src/index.ts"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "werift": "^0.22.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3"
  }
}
